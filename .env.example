# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub
GITHUB_TOKEN=your_github_token_here

# Jira
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@yourorg.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=QE

# Webhook Server
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here
JIRA_WEBHOOK_SECRET=your_jira_webhook_secret_here

# ngrok tunnel (for local development — get token at https://dashboard.ngrok.com)
NGROK_AUTH_TOKEN=your_ngrok_auth_token_here
NGROK_DOMAIN=                        # optional: your reserved domain e.g. qe-agent.ngrok.app

# Event Streaming (Kafka/PubSub)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PRODUCT_SIGNALS=product-signals
PUBSUB_PROJECT_ID=your-gcp-project
PUBSUB_SUBSCRIPTION=qe-agent-sub

# Test Infrastructure
DEVICE_FARM_ENDPOINT=http://localhost:4444
DEVICE_FARM_CONCURRENCY=4

# Metrics
METRICS_ENABLED=true
METRICS_ENDPOINT=http://localhost:9091

# Git
GIT_COMMIT_AUTO_HEAL=false
